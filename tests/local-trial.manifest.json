{
  "version": 1,
  "id": "local-runner-fixture",
  "title": "Local runner fixture",
  "task": "Build a small web application from the supplied documentation.",
  "documents": [
    {
      "label": "Example documentation",
      "kind": "markdown",
      "value": "# Example\n\nBuild the documented application."
